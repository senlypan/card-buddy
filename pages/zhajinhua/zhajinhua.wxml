<!--pages/zhajinhua/zhajinhua.wxml - iPad 竖屏优化版-->
<view class="container">
  <!-- 游戏信息栏（顶部固定） -->
  <view class="game-info-bar">
    <view class="info-item">
      <text class="info-label">第 {{round}} 局</text>
    </view>
    <view class="info-item points">
      <text class="info-label">积分</text>
      <text class="info-value">{{myPoints}}</text>
    </view>
    <view class="info-item bet">
      <text class="info-label">下注</text>
      <text class="info-value">{{betAmount}}</text>
    </view>
  </view>

  <!-- 牌友区域（上方） -->
  <view class="player-area buddy-area">
    <view class="avatar-large">🃏</view>
    <view class="player-content">
      <text class="player-name">牌牌</text>
      <view class="cards-small">
        <block wx:if="{{!showBuddyCards}}">
          <view class="card-mini back" wx:for="{{3}}" wx:key="*this"></view>
        </block>
        <block wx:else>
          <view class="card-mini" wx:for="{{buddyCardsDisplay}}" wx:key="*this">
            <text class="card-text {{item.isRed ? 'card-red' : 'card-black'}}">{{item.text}}</text>
          </view>
        </block>
      </view>
      <view class="hand-type-badge" wx:if="{{showBuddyCards && buddyHandType}}">
        <text>{{buddyHandType.type}}</text>
      </view>
    </view>
  </view>

  <!-- 游戏提示（中间） -->
  <view class="message-box-compact">
    <text class="message-text">{{message}}</text>
  </view>

  <!-- 我的手牌区域（下方） -->
  <view class="player-area my-area">
    <view class="player-content">
      <text class="player-name">我</text>
      
      <!-- 未看牌 -->
      <view class="cards-medium" wx:if="{{!showMyCards}}">
        <view class="card-back" wx:for="{{3}}" wx:key="*this"></view>
      </view>
      
      <!-- 已看牌 -->
      <view class="cards-medium" wx:else>
        <view class="card-normal" wx:for="{{myCardsDisplay}}" wx:key="*this">
          <text class="card-text {{item.isRed ? 'card-red' : 'card-black'}}">{{item.text}}</text>
        </view>
      </view>
      
      <!-- 牌型提示 -->
      <view class="hand-type-badge my-type" wx:if="{{showMyCards && myHandType}}">
        <text>{{myHandType.type}}</text>
      </view>
      
      <!-- 盲打标识 -->
      <view class="blind-badge-compact" wx:if="{{!showMyCards && gamePhase === 'betting'}}">
        <text>🎯 盲打</text>
      </view>
    </view>
    <view class="avatar-large">👦</view>
  </view>

  <!-- 概率提示（紧凑版） -->
  <view class="probability-compact" wx:if="{{showProbability && handAnalysis}}">
    <view class="prob-line">
      <text class="prob-text">{{handAnalysis.explanation}}</text>
    </view>
    <view class="prob-line">
      <text class="prob-label">胜率：</text>
      <text class="prob-value" style="color: #2ecc71">{{handAnalysis.winRate.rate}}%</text>
      <text class="prob-sub">({{handAnalysis.winRate.text}})</text>
    </view>
    <view class="prob-line suggestion" style="border-left-color: {{handAnalysis.suggestion.color}}">
      <text class="prob-emoji">{{handAnalysis.suggestion.emoji}}</text>
      <text class="prob-action" style="color: {{handAnalysis.suggestion.color}}">{{handAnalysis.suggestion.action}}</text>
      <text class="prob-reason">{{handAnalysis.suggestion.reason}}</text>
    </view>
  </view>

  <!-- 操作按钮区域（底部固定） -->
  <view class="action-bar">
    <!-- 看牌选择 -->
    <view class="button-row" wx:if="{{gamePhase === 'choose'}}">
      <view class="btn-medium look" bindtap="lookCards">👀 看牌</view>
      <view class="btn-medium blind" bindtap="dontLookCards">🎯 盲打</view>
    </view>
    
    <!-- 下注操作 -->
    <view class="button-row" wx:if="{{gamePhase === 'betting' && !isRaised}}">
      <view class="btn-medium raise" bindtap="showRaiseInput">📈 加注</view>
      <view class="btn-medium call" bindtap="call">✅ 开牌</view>
    </view>
    
    <!-- 开牌 -->
    <view class="button-row" wx:if="{{isRaised && !showBuddyCards}}">
      <view class="btn-large showdown" bindtap="showdown">🎲 开牌比大小</view>
    </view>
    
    <!-- 再来一局 -->
    <view class="button-row" wx:if="{{gamePhase === 'result'}}">
      <view class="btn-large next" bindtap="nextRound">🃏 再来一局</view>
    </view>
  </view>

  <!-- 结算弹窗 -->
  <view class="modal-compact" wx:if="{{showResult}}" bindtap="closeResult">
    <view class="modal-content-compact" catchtap="stopClose">
      <text class="result-emoji-compact">{{resultEmoji}}</text>
      <text class="result-title-compact">{{resultTitle}}</text>
      <text class="result-points-compact">{{resultPoints}}</text>
      
      <!-- 手动关闭按钮 -->
      <view class="close-button-row">
        <view class="btn-close" bindtap="closeResult">
          <text>✕ 关闭</text>
        </view>
      </view>
      
      <view class="countdown-compact" wx:if="{{countdown > 0}}">
        <text>{{countdown}}秒后自动关闭</text>
      </view>
    </view>
  </view>

  <!-- 加注弹窗 -->
  <view class="modal-compact" wx:if="{{showRaiseInput}}" bindtap="closeRaiseInput">
    <view class="raise-dialog-compact" catchtap="stopClose">
      <text class="raise-title-compact">📈 加注多少？</text>
      
      <!-- 当前信息 -->
      <view class="raise-info-row">
        <view class="info-card">
          <text class="info-label">当前下注</text>
          <text class="info-value">{{betAmount}}</text>
        </view>
        <view class="info-card">
          <text class="info-label">剩余积分</text>
          <text class="info-value total">{{myPoints}}</text>
        </view>
      </view>
      
      <!-- 快捷金额 -->
      <view class="quick-amounts">
        <view class="quick-btn" bindtap="setQuickAmount" data-amount="10">
          <text class="quick-value">10</text>
          <text class="quick-label">分</text>
        </view>
        <view class="quick-btn" bindtap="setQuickAmount" data-amount="20">
          <text class="quick-value">20</text>
          <text class="quick-label">分</text>
        </view>
        <view class="quick-btn" bindtap="setQuickAmount" data-amount="50">
          <text class="quick-value">50</text>
          <text class="quick-label">分</text>
        </view>
        <view class="quick-btn all-in" bindtap="setQuickAmount" data-amount="{{myPoints}}">
          <text class="quick-value">ALL IN</text>
          <text class="quick-label">全押</text>
        </view>
      </view>
      
      <!-- 滑块调节 -->
      <view class="slider-section">
        <text class="slider-label">或自定义金额：</text>
        <view class="slider-compact">
          <slider 
            class="raise-slider"
            min="1" 
            max="{{myPoints}}" 
            value="{{customRaiseAmount}}"
            block-size="20"
            activeColor="#FF6B6B"
            bindchange="onSliderChange"
          />
        </view>
        <view class="amount-display-compact">
          <text class="amount-number">{{customRaiseAmount}}</text>
          <text class="amount-unit">分</text>
        </view>
      </view>
      
      <!-- 操作按钮 -->
      <view class="button-row-compact">
        <view class="btn-small cancel" bindtap="closeRaiseInput">取消</view>
        <view class="btn-small confirm" bindtap="customRaise">确定加注</view>
      </view>
    </view>
  </view>

  <!-- 庆祝特效 -->
  <view class="confetti-compact" wx:if="{{showConfetti}}">
    <text class="confetti-item">🎉</text>
    <text class="confetti-item">✨</text>
    <text class="confetti-item">🌟</text>
  </view>
</view>
