/* pages/zhajinhua/zhajinhua.wxss - iPad 适配优化版 */

/* 容器 - 高级渐变背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding-bottom: 30rpx;
  max-width: 1024px;
  margin: 0 auto;
}

/* 游戏信息栏 - 玻璃态效果 */
.game-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  margin: 15rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.3);
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.points {
  font-size: 34rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 16rpx rgba(255, 215, 0, 0.5);
}

.bet-amount {
  font-size: 30rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 玩家区域 - 悬浮卡片效果 */
.player-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 20rpx;
  margin: 15rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.4);
  position: relative;
  overflow: hidden;
}

.player-area::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
}

.buddy-area {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.15) 0%, rgba(255, 107, 107, 0.05) 100%);
}

.my-area {
  background: linear-gradient(135deg, rgba(78, 205, 196, 0.15) 0%, rgba(78, 205, 196, 0.05) 100%);
}

.avatar {
  font-size: 70rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.5));
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 15rpx;
}

.name {
  font-size: 26rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  letter-spacing: 1rpx;
}

.cards {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.card {
  width: 60rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.4), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.5);
  transition: transform 0.3s ease;
  position: relative;
}

.card::before {
  content: '';
  position: absolute;
  top: 3rpx;
  left: 3rpx;
  right: 3rpx;
  bottom: 3rpx;
  border-radius: 9rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.card.back {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border: 2rpx solid #c0392b;
}

.card.back::after {
  content: '🃏';
  font-size: 32rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.3));
}

.card.large {
  width: 76rpx;
  height: 112rpx;
  border-width: 2rpx;
  transform: translateY(-4rpx);
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.5), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.6);
}

.card-text {
  font-size: 26rpx;
  font-weight: bold;
  z-index: 1;
}

.card.large .card-text {
  font-size: 32rpx;
}

/* 扑克牌花色颜色 */
.card-red {
  color: #e74c3c;
  text-shadow: 0 0 8rpx rgba(231, 76, 60, 0.4);
}

.card-black {
  color: #2c3e50;
  text-shadow: 0 0 8rpx rgba(44, 62, 80, 0.3);
}

/* 牌型提示 - 霓虹效果 */
.hand-type {
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.3) 0%, rgba(142, 68, 173, 0.2) 100%);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  margin-top: 8rpx;
  border: 1rpx solid rgba(155, 89, 182, 0.4);
  box-shadow: 0 3rpx 12rpx rgba(155, 89, 182, 0.3);
}

.my-hand-type {
  background: linear-gradient(135deg, rgba(26, 188, 156, 0.3) 0%, rgba(22, 160, 133, 0.2) 100%);
  border: 1rpx solid rgba(26, 188, 156, 0.4);
  box-shadow: 0 3rpx 12rpx rgba(26, 188, 156, 0.3);
}

.hand-type-text {
  font-size: 22rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.5);
}

/* 加注标识 */
.raise-badge {
  margin-top: 8rpx;
  padding: 5rpx 14rpx;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.raise-badge text {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

/* 盲打标识 */
.blind-badge {
  margin-top: 8rpx;
  padding: 5rpx 14rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.blind-badge text {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

/* 消息框 - 呼吸灯效果 */
.message-box {
  text-align: center;
  padding: 20rpx;
  margin: 12rpx 15rpx;
}

.message {
  font-size: 30rpx;
  color: white;
  font-weight: bold;
  line-height: 1.5;
  text-shadow: 0 0 16rpx rgba(255, 255, 255, 0.5);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.8; }
}

/* 操作按钮区域 */
.action-area {
  padding: 20rpx 15rpx;
}

.big-btn {
  width: 85%;
  height: 100rpx;
  margin: 12rpx auto;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.4);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.big-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s ease;
}

.big-btn:active::before {
  left: 100%;
}

.big-btn:active {
  transform: scale(0.95);
}

.look-btn {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.blind-btn {
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.showdown-btn {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.next-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 中等按钮（加注/不加注） */
.bet-buttons {
  display: flex;
  gap: 15rpx;
  justify-content: center;
}

.medium-btn {
  width: 42%;
  height: 92rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  transition: all 0.2s ease;
}

.medium-btn:active {
  transform: scale(0.95);
}

.raise-btn {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.call-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 结算弹窗 - 毛玻璃效果 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: 32rpx;
  padding: 50rpx 70rpx;
  text-align: center;
  animation: popIn 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

@keyframes popIn {
  from {
    transform: scale(0.5) rotate(-10deg);
    opacity: 0;
  }
  to {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.result-emoji {
  font-size: 110rpx;
  display: block;
  animation: bounce 0.8s ease;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.3));
}

.result-title {
  font-size: 44rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  margin: 20rpx 0 12rpx;
}

.result-points {
  font-size: 40rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: bold;
  display: block;
}

.result-subtitle {
  font-size: 26rpx;
  color: #95a5a6;
  display: block;
  margin-top: 16rpx;
}

/* 关闭按钮 */
.close-btn {
  margin-top: 28rpx;
  padding: 14rpx 40rpx;
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  border-radius: 28rpx;
  display: inline-block;
  box-shadow: 0 5rpx 16rpx rgba(149, 165, 166, 0.4);
  transition: all 0.2s ease;
}

.close-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.close-btn text {
  font-size: 26rpx;
  color: white;
  font-weight: bold;
}

/* 倒计时显示 */
.countdown {
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, rgba(52, 152, 219, 0.2) 0%, rgba(41, 128, 185, 0.1) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(52, 152, 219, 0.3);
}

.countdown text {
  font-size: 24rpx;
  color: #3498db;
  font-weight: 500;
}

/* 庆祝特效 */
.confetti {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 999;
}

.confetti-item {
  position: absolute;
  top: -50rpx;
  font-size: 56rpx;
  animation: fall 2.5s ease-in-out infinite;
  filter: drop-shadow(0 2rpx 8rpx rgba(0, 0, 0, 0.3));
}

.confetti-item:nth-child(1) { animation-delay: 0s; }
.confetti-item:nth-child(2) { animation-delay: 0.3s; }
.confetti-item:nth-child(3) { animation-delay: 0.6s; }
.confetti-item:nth-child(4) { animation-delay: 0.9s; }
.confetti-item:nth-child(5) { animation-delay: 1.2s; }

@keyframes fall {
  0% {
    top: -50rpx;
    transform: rotate(0deg) scale(0.8);
    opacity: 1;
  }
  100% {
    top: 100vh;
    transform: rotate(720deg) scale(1.2);
    opacity: 0;
  }
}

/* 加注输入框弹窗 */
.raise-input-content {
  background: white;
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  text-align: center;
  animation: popIn 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.5);
  width: 80%;
  max-width: 600rpx;
}

.raise-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.raise-subtitle {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 30rpx;
}

.input-section {
  margin: 30rpx 0;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.raise-slider {
  margin: 20rpx 0;
}

.input-value-box {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 20rpx;
}

.raise-input {
  width: 200rpx;
  height: 80rpx;
  border: 2rpx solid #FF6B6B;
  border-radius: 12rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.input-unit {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.quick-amounts {
  display: flex;
  justify-content: space-around;
  margin: 30rpx 0;
}

.quick-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: white;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.quick-btn:active {
  transform: scale(0.95);
}

.raise-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
}

.cancel-btn {
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  color: white;
}

.confirm-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
}

.cancel-btn:active,
.confirm-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* iPad 横屏适配 */
@media (min-width: 768px) and (orientation: landscape) {
  .container {
    padding: 20rpx;
  }
  
  .player-area {
    padding: 20rpx;
    margin: 10rpx;
  }
  
  .card {
    width: 56rpx;
    height: 82rpx;
  }
  
  .card.large {
    width: 70rpx;
    height: 104rpx;
  }
  
  .card-text {
    font-size: 24rpx;
  }
  
  .card.large .card-text {
    font-size: 28rpx;
  }
}
