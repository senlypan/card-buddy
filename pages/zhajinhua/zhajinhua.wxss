/* pages/zhajinhua/zhajinhua.wxss */
.game-info {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: white;
  border-radius: 16rpx;
  margin: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 24rpx;
  color: #999;
}

.points {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.player-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  margin: 20rpx;
  background: white;
  border-radius: 24rpx;
}

.buddy-area {
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE5E5 100%);
}

.my-area {
  background: linear-gradient(135deg, #E5F5FF 0%, #F0F9FF 100%);
}

.avatar {
  font-size: 80rpx;
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.cards {
  display: flex;
  gap: 10rpx;
}

.card {
  width: 80rpx;
  height: 120rpx;
  background: white;
  border-radius: 8rpx;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.card.back {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border: 2rpx solid #FF6B6B;
}

.card.large {
  width: 100rpx;
  height: 150rpx;
}

.card-text {
  font-size: 28rpx;
  font-weight: bold;
}

.card.large .card-text {
  font-size: 36rpx;
}

.message-box {
  text-align: center;
  padding: 20rpx;
  margin: 20rpx;
}

.message {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.action-area {
  padding: 20rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 32rpx;
  padding: 60rpx;
  text-align: center;
  animation: popIn 0.3s ease;
}

@keyframes popIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.result-emoji {
  font-size: 120rpx;
  display: block;
}

.result-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin: 20rpx 0;
}

.result-points {
  font-size: 40rpx;
  color: #FF6B6B;
  font-weight: bold;
}
