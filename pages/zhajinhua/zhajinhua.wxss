/* pages/zhajinhua/zhajinhua.wxss - 高级版炸金花 */

/* 容器 - 高级渐变背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding-bottom: 40rpx;
}

/* 游戏信息栏 - 玻璃态效果 */
.game-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 35rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  margin: 25rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.points {
  font-size: 44rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

/* 玩家区域 - 悬浮卡片效果 */
.player-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx 30rpx;
  margin: 25rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
  position: relative;
  overflow: hidden;
}

.player-area::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
}

.buddy-area {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.15) 0%, rgba(255, 107, 107, 0.05) 100%);
}

.my-area {
  background: linear-gradient(135deg, rgba(78, 205, 196, 0.15) 0%, rgba(78, 205, 196, 0.05) 100%);
}

.avatar {
  font-size: 90rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.5));
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 25rpx;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  letter-spacing: 2rpx;
}

.cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.card {
  width: 85rpx;
  height: 125rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 14rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.5);
  transition: transform 0.3s ease;
  position: relative;
}

.card::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  right: 4rpx;
  bottom: 4rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.card.back {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border: 2rpx solid #c0392b;
}

.card.back::after {
  content: '🃏';
  font-size: 44rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.3));
}

.card.large {
  width: 110rpx;
  height: 160rpx;
  border-width: 3rpx;
  transform: translateY(-5rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.5), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.6);
}

.card-text {
  font-size: 32rpx;
  font-weight: bold;
  z-index: 1;
}

.card.large .card-text {
  font-size: 40rpx;
}

/* 扑克牌花色颜色 */
.card-red {
  color: #e74c3c;
  text-shadow: 0 0 10rpx rgba(231, 76, 60, 0.4);
}

.card-black {
  color: #2c3e50;
  text-shadow: 0 0 10rpx rgba(44, 62, 80, 0.3);
}

/* 牌型提示 - 霓虹效果 */
.hand-type {
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.3) 0%, rgba(142, 68, 173, 0.2) 100%);
  padding: 10rpx 25rpx;
  border-radius: 24rpx;
  margin-top: 15rpx;
  border: 1rpx solid rgba(155, 89, 182, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(155, 89, 182, 0.3);
}

.my-hand-type {
  background: linear-gradient(135deg, rgba(26, 188, 156, 0.3) 0%, rgba(22, 160, 133, 0.2) 100%);
  border: 1rpx solid rgba(26, 188, 156, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(26, 188, 156, 0.3);
}

.hand-type-text {
  font-size: 26rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
}

/* 消息框 - 呼吸灯效果 */
.message-box {
  text-align: center;
  padding: 30rpx;
  margin: 20rpx 25rpx;
}

.message {
  font-size: 36rpx;
  color: white;
  font-weight: bold;
  line-height: 1.5;
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.5);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.8; }
}

/* 操作按钮区域 */
.action-area {
  padding: 30rpx 25rpx;
}

.big-btn {
  width: 90%;
  height: 140rpx;
  margin: 0 auto;
  border-radius: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.big-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s ease;
}

.big-btn:active::before {
  left: 100%;
}

.big-btn:active {
  transform: scale(0.95);
}

.showdown-btn {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.next-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 结算弹窗 - 毛玻璃效果 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: 40rpx;
  padding: 70rpx 90rpx;
  text-align: center;
  animation: popIn 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

@keyframes popIn {
  from {
    transform: scale(0.5) rotate(-10deg);
    opacity: 0;
  }
  to {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.result-emoji {
  font-size: 140rpx;
  display: block;
  animation: bounce 0.8s ease;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.3));
}

.result-title {
  font-size: 52rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  margin: 25rpx 0 15rpx;
}

.result-points {
  font-size: 48rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: bold;
  display: block;
}

.result-subtitle {
  font-size: 30rpx;
  color: #95a5a6;
  display: block;
  margin-top: 20rpx;
}

/* 关闭按钮 */
.close-btn {
  margin-top: 35rpx;
  padding: 18rpx 50rpx;
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  border-radius: 35rpx;
  display: inline-block;
  box-shadow: 0 6rpx 20rpx rgba(149, 165, 166, 0.4);
  transition: all 0.2s ease;
}

.close-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.close-btn text {
  font-size: 30rpx;
  color: white;
  font-weight: bold;
}

/* 倒计时显示 */
.countdown {
  margin-top: 20rpx;
  padding: 12rpx 30rpx;
  background: linear-gradient(135deg, rgba(52, 152, 219, 0.2) 0%, rgba(41, 128, 185, 0.1) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(52, 152, 219, 0.3);
}

.countdown text {
  font-size: 26rpx;
  color: #3498db;
  font-weight: 500;
}

/* 庆祝特效 */
.confetti {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 999;
}

.confetti-item {
  position: absolute;
  top: -60rpx;
  font-size: 70rpx;
  animation: fall 2.5s ease-in-out infinite;
  filter: drop-shadow(0 2rpx 8rpx rgba(0, 0, 0, 0.3));
}

.confetti-item:nth-child(1) { animation-delay: 0s; }
.confetti-item:nth-child(2) { animation-delay: 0.3s; }
.confetti-item:nth-child(3) { animation-delay: 0.6s; }
.confetti-item:nth-child(4) { animation-delay: 0.9s; }
.confetti-item:nth-child(5) { animation-delay: 1.2s; }

@keyframes fall {
  0% {
    top: -60rpx;
    transform: rotate(0deg) scale(0.8);
    opacity: 1;
  }
  100% {
    top: 100vh;
    transform: rotate(720deg) scale(1.2);
    opacity: 0;
  }
}
