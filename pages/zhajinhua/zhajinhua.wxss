/* pages/zhajinhua/zhajinhua.wxss - 豪华版 */

/* 容器 - 高级渐变背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding-bottom: 30rpx;
  max-width: 1024px;
  margin: 0 auto;
}

/* 游戏信息栏 - 玻璃态效果 */
.game-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  margin: 15rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.3);
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.points {
  font-size: 34rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 16rpx rgba(255, 215, 0, 0.5);
}

.bet-amount {
  font-size: 30rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 玩家区域 - 悬浮卡片效果 */
.player-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 20rpx;
  margin: 15rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.4);
  position: relative;
  overflow: hidden;
}

.player-area::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
}

.buddy-area {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.15) 0%, rgba(255, 107, 107, 0.05) 100%);
}

.my-area {
  background: linear-gradient(135deg, rgba(78, 205, 196, 0.15) 0%, rgba(78, 205, 196, 0.05) 100%);
}

.avatar {
  font-size: 70rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.5));
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 15rpx;
}

.name {
  font-size: 26rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  letter-spacing: 1rpx;
}

.cards {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.card {
  width: 60rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.4), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.5);
  transition: transform 0.3s ease;
  position: relative;
}

.card::before {
  content: '';
  position: absolute;
  top: 3rpx;
  left: 3rpx;
  right: 3rpx;
  bottom: 3rpx;
  border-radius: 9rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.card.back {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border: 2rpx solid #c0392b;
}

.card.back::after {
  content: '🃏';
  font-size: 32rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.3));
}

.card.large {
  width: 76rpx;
  height: 112rpx;
  border-width: 2rpx;
  transform: translateY(-4rpx);
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.5), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.6);
}

.card-text {
  font-size: 26rpx;
  font-weight: bold;
  z-index: 1;
}

.card.large .card-text {
  font-size: 32rpx;
}

/* 扑克牌花色颜色 */
.card-red {
  color: #e74c3c;
  text-shadow: 0 0 8rpx rgba(231, 76, 60, 0.4);
}

.card-black {
  color: #2c3e50;
  text-shadow: 0 0 8rpx rgba(44, 62, 80, 0.3);
}

/* 发牌动画 */
.card.dealing {
  animation: dealCard 0.3s ease-out forwards;
  opacity: 0;
  transform: translateY(-100rpx) scale(0.8);
}

@keyframes dealCard {
  0% {
    opacity: 0;
    transform: translateY(-100rpx) scale(0.8) rotate(10deg);
  }
  70% {
    transform: translateY(10rpx) scale(1.05) rotate(-5deg);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1) rotate(0);
  }
}

/* 牌面翻转动画 */
.card.flip {
  animation: flipCard 0.4s ease-in-out forwards;
}

@keyframes flipCard {
  0% {
    transform: rotateY(0deg);
  }
  50% {
    transform: rotateY(90deg);
  }
  100% {
    transform: rotateY(0deg);
  }
}

/* 加注按钮脉冲动画 */
.raise-btn.pulsing {
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 8rpx 24rpx rgba(231, 76, 60, 0.4);
  }
  50% {
    box-shadow: 0 8rpx 32rpx rgba(231, 76, 60, 0.6);
  }
}

/* 牌型提示 - 霓虹效果 */
.hand-type {
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.3) 0%, rgba(142, 68, 173, 0.2) 100%);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  margin-top: 8rpx;
  border: 1rpx solid rgba(155, 89, 182, 0.4);
  box-shadow: 0 3rpx 12rpx rgba(155, 89, 182, 0.3);
}

.my-hand-type {
  background: linear-gradient(135deg, rgba(26, 188, 156, 0.3) 0%, rgba(22, 160, 133, 0.2) 100%);
  border: 1rpx solid rgba(26, 188, 156, 0.4);
  box-shadow: 0 3rpx 12rpx rgba(26, 188, 156, 0.3);
}

.hand-type-text {
  font-size: 22rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.5);
}

/* 加注标识 */
.raise-badge {
  margin-top: 8rpx;
  padding: 5rpx 14rpx;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.raise-badge text {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

/* 盲打标识 */
.blind-badge {
  margin-top: 8rpx;
  padding: 5rpx 14rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.blind-badge text {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

/* 消息框 - 呼吸灯效果 */
.message-box {
  text-align: center;
  padding: 20rpx;
  margin: 12rpx 15rpx;
}

.message {
  font-size: 30rpx;
  color: white;
  font-weight: bold;
  line-height: 1.5;
  text-shadow: 0 0 16rpx rgba(255, 255, 255, 0.5);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.8; }
}

/* 操作按钮区域 */
.action-area {
  padding: 20rpx 15rpx;
}

.big-btn {
  width: 85%;
  height: 100rpx;
  margin: 12rpx auto;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.4);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.big-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s ease;
}

.big-btn:active::before {
  left: 100%;
}

.big-btn:active {
  transform: scale(0.95);
}

.look-btn {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.blind-btn {
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.showdown-btn {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.next-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 中等按钮（加注/不加注） */
.bet-buttons {
  display: flex;
  gap: 15rpx;
  justify-content: center;
}

.medium-btn {
  width: 42%;
  height: 92rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  transition: all 0.2s ease;
}

.medium-btn:active {
  transform: scale(0.95);
}

.raise-btn {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.call-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 结算弹窗 - 毛玻璃效果 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: 32rpx;
  padding: 50rpx 70rpx;
  text-align: center;
  animation: popIn 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

@keyframes popIn {
  from {
    transform: scale(0.5) rotate(-10deg);
    opacity: 0;
  }
  to {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.result-emoji {
  font-size: 110rpx;
  display: block;
  animation: bounce 0.8s ease;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.3));
}

.result-title {
  font-size: 44rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  margin: 20rpx 0 12rpx;
}

.result-points {
  font-size: 40rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: bold;
  display: block;
}

.result-subtitle {
  font-size: 26rpx;
  color: #95a5a6;
  display: block;
  margin-top: 16rpx;
}

/* 关闭按钮 */
.close-btn {
  margin-top: 28rpx;
  padding: 14rpx 40rpx;
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  border-radius: 28rpx;
  display: inline-block;
  box-shadow: 0 5rpx 16rpx rgba(149, 165, 166, 0.4);
  transition: all 0.2s ease;
}

.close-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.close-btn text {
  font-size: 26rpx;
  color: white;
  font-weight: bold;
}

/* 倒计时显示 */
.countdown {
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, rgba(52, 152, 219, 0.2) 0%, rgba(41, 128, 185, 0.1) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(52, 152, 219, 0.3);
}

.countdown text {
  font-size: 24rpx;
  color: #3498db;
  font-weight: 500;
}

/* 庆祝特效 */
.confetti {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 999;
}

.confetti-item {
  position: absolute;
  top: -50rpx;
  font-size: 56rpx;
  animation: fall 2.5s ease-in-out infinite;
  filter: drop-shadow(0 2rpx 8rpx rgba(0, 0, 0, 0.3));
}

.confetti-item:nth-child(1) { animation-delay: 0s; }
.confetti-item:nth-child(2) { animation-delay: 0.3s; }
.confetti-item:nth-child(3) { animation-delay: 0.6s; }
.confetti-item:nth-child(4) { animation-delay: 0.9s; }
.confetti-item:nth-child(5) { animation-delay: 1.2s; }

@keyframes fall {
  0% {
    top: -50rpx;
    transform: rotate(0deg) scale(0.8);
    opacity: 1;
  }
  100% {
    top: 100vh;
    transform: rotate(720deg) scale(1.2);
    opacity: 0;
  }
}

/* ===== 豪华版加注弹窗 ===== */

.raise-modal .raise-dialog {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 40rpx;
  padding: 0;
  width: 85%;
  max-width: 640rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 100rpx rgba(0, 0, 0, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  animation: slideUp 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* 顶部装饰 */
.raise-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 40rpx 30rpx 30rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.raise-header::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  animation: shimmer 3s linear infinite;
}

@keyframes shimmer {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.raise-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 10rpx;
  animation: bounce 2s ease-in-out infinite;
}

.raise-title {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.raise-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

/* 信息面板 */
.info-panel {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  margin: 0 20rpx;
  border-radius: 20rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
}

.info-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.info-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.info-value {
  font-size: 40rpx;
  font-weight: bold;
}

.info-value.current {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.info-value.total {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.info-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.info-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.2), transparent);
}

/* 加注金额设置 */
.amount-section {
  padding: 30rpx 30rpx 20rpx;
}

.section-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.slider-container {
  margin: 20rpx 0;
  padding: 0 10rpx;
}

.raise-slider {
  width: 100%;
}

.amount-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 10rpx;
  margin: 25rpx 0;
  padding: 20rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.3);
}

.amount-number {
  font-size: 64rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}

.amount-unit {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: bold;
}

.input-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  margin-top: 20rpx;
}

.amount-input {
  width: 240rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  transition: all 0.3s;
}

.amount-input:focus {
  border-color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
}

.input-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 快捷金额 */
.quick-section {
  padding: 20rpx 30rpx 30rpx;
}

.quick-buttons {
  display: flex;
  justify-content: space-between;
  gap: 15rpx;
  margin-top: 15rpx;
}

.quick-btn {
  flex: 1;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.quick-btn:active {
  transform: scale(0.95);
  background: rgba(255, 107, 107, 0.2);
  border-color: #FF6B6B;
}

.quick-btn.all-in {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.2) 0%, rgba(255, 142, 142, 0.1) 100%);
  border-color: #FF6B6B;
}

.quick-value {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.quick-btn.all-in .quick-value {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.quick-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 30rpx;
}

.action-buttons .btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  transition: all 0.2s ease;
}

.action-buttons .btn:active {
  transform: scale(0.95);
}

.action-buttons .btn.cancel {
  background: linear-gradient(135deg, #5a5a5a 0%, #4a4a4a 100%);
  color: white;
}

.action-buttons .btn.confirm {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
  box-shadow: 0 8rpx 24rpx rgba(46, 204, 113, 0.4);
}

/* iPad 横屏适配 */
@media (min-width: 768px) and (orientation: landscape) {
  .container {
    padding: 20rpx;
  }
  
  .player-area {
    padding: 20rpx;
    margin: 10rpx;
  }
  
  .card {
    width: 56rpx;
