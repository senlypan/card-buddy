/* pages/zhajinhua/zhajinhua.wxss - iPad 竖屏优化版 */

/* 容器 - 紧凑布局，不滚动 */
.container {
  height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 游戏信息栏（顶部固定） */
.game-info-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 0 0 16rpx 16rpx;
  flex-shrink: 0;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.info-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFD700;
}

.info-item.points .info-value {
  color: #2ecc71;
}

.info-item.bet .info-value {
  color: #3498db;
}

/* 玩家区域 */
.player-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 20rpx;
  margin: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  flex-shrink: 0;
}

.buddy-area {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.15) 0%, rgba(255, 107, 107, 0.05) 100%);
}

.my-area {
  background: linear-gradient(135deg, rgba(78, 205, 196, 0.15) 0%, rgba(78, 205, 196, 0.05) 100%);
}

.avatar-large {
  font-size: 64rpx;
  flex-shrink: 0;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.player-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 12rpx;
}

.player-name {
  font-size: 24rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

/* 牌型徽章 */
.hand-type-badge {
  padding: 4rpx 12rpx;
  background: rgba(155, 89, 182, 0.3);
  border-radius: 12rpx;
  margin-top: 6rpx;
  border: 1rpx solid rgba(155, 89, 182, 0.4);
}

.hand-type-badge text {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

.hand-type-badge.my-type {
  background: rgba(26, 188, 156, 0.3);
  border-color: rgba(26, 188, 156, 0.4);
}

/* 牌型样式 */
.cards-small {
  display: flex;
  gap: 6rpx;
}

.card-mini {
  width: 40rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.card-mini.back {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-color: #c0392b;
}

.card-mini .card-text {
  font-size: 18rpx;
  font-weight: bold;
}

.cards-medium {
  display: flex;
  gap: 8rpx;
}

.card-normal {
  width: 56rpx;
  height: 84rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 10rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.4);
}

.card-normal .card-text {
  font-size: 24rpx;
  font-weight: bold;
}

.card-red {
  color: #e74c3c;
}

.card-black {
  color: #2c3e50;
}

.card-back {
  width: 56rpx;
  height: 84rpx;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-radius: 10rpx;
  border: 2rpx solid #c0392b;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.4);
}

/* 盲打标识 */
.blind-badge-compact {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  border-radius: 12rpx;
  margin-top: 6rpx;
}

.blind-badge-compact text {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

/* 游戏提示 */
.message-box-compact {
  text-align: center;
  padding: 8rpx;
  flex-shrink: 0;
}

.message-text {
  font-size: 26rpx;
  color: white;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

/* 概率提示（紧凑版） */
.probability-compact {
  padding: 10rpx 16rpx;
  margin: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.prob-line {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 0;
}

.prob-text {
  font-size: 22rpx;
  color: white;
  line-height: 1.4;
}

.prob-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.prob-value {
  font-size: 26rpx;
  font-weight: bold;
}

.prob-sub {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.6);
}

.prob-action {
  font-size: 24rpx;
  font-weight: bold;
}

.prob-reason {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
}

.prob-emoji {
  font-size: 24rpx;
}

.suggestion {
  margin-top: 6rpx;
  padding-left: 10rpx;
  border-left: 3rpx solid;
}

/* 操作按钮区域（底部固定） */
.action-bar {
  padding: 12rpx 20rpx;
  flex-shrink: 0;
}

.button-row {
  display: flex;
  gap: 12rpx;
  justify-content: center;
}

.btn-medium {
  flex: 1;
  max-width: 200rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.3);
  transition: all 0.2s;
}

.btn-medium:active {
  transform: scale(0.95);
}

.btn-medium.look {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: white;
}

.btn-medium.blind {
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: white;
}

.btn-medium.raise {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: white;
}

.btn-medium.call {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
}

.btn-large {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
}

.btn-large:active {
  transform: scale(0.95);
}

.btn-large.showdown {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: white;
}

.btn-large.next {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
}

/* 结算弹窗（紧凑版） */
.modal-compact {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content-compact {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: 24rpx;
  padding: 40rpx 60rpx;
  text-align: center;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.5);
}

.result-emoji-compact {
  font-size: 80rpx;
  display: block;
}

.result-title-compact {
  font-size: 36rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: block;
  margin: 16rpx 0 10rpx;
}

.result-points-compact {
  font-size: 32rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: bold;
  display: block;
}

.countdown-compact {
  margin-top: 12rpx;
  padding: 8rpx 20rpx;
  background: rgba(52, 152, 219, 0.2);
  border-radius: 16rpx;
}

.countdown-compact text {
  font-size: 20rpx;
  color: #3498db;
}

/* 手动关闭按钮 */
.close-button-row {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

.btn-close {
  padding: 12rpx 40rpx;
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(149, 165, 166, 0.4);
  transition: all 0.2s;
}

.btn-close:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.btn-close text {
  font-size: 26rpx;
  color: white;
  font-weight: bold;
}

/* 加注弹窗 */
.raise-dialog-compact {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  width: 85%;
  max-width: 560rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  max-height: 80vh;
  overflow-y: auto;
}

.raise-title-compact {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  display: block;
  text-align: center;
  margin-bottom: 20rpx;
}

/* 当前信息行 */
.raise-info-row {
  display: flex;
  justify-content: space-around;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.info-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.info-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 6rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #2ecc71;
}

.info-value.total {
  color: #FFD700;
}

/* 快捷金额 */
.quick-amounts {
  display: flex;
  gap: 12rpx;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.quick-btn {
  flex: 1;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.2s;
}

.quick-btn:active {
  transform: scale(0.95);
  background: rgba(255, 107, 107, 0.2);
  border-color: #FF6B6B;
}

.quick-btn.all-in {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.2) 0%, rgba(255, 142, 142, 0.1) 100%);
  border-color: #FF6B6B;
}

.quick-value {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}

.quick-btn.all-in .quick-value {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.quick-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 滑块区域 */
.slider-section {
  margin-bottom: 20rpx;
}

.slider-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 12rpx;
  text-align: center;
}

.slider-compact {
  margin: 12rpx 0;
}

.amount-display-compact {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin: 12rpx 0;
  padding: 12rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 107, 107, 0.3);
}

.amount-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.amount-unit {
  font-size: 24rpx;
  color: #FF6B6B;
}

.button-row-compact {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.btn-small {
  flex: 1;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
}

.btn-small.cancel {
  background: linear-gradient(135deg, #5a5a5a 0%, #4a4a4a 100%);
  color: white;
}

.btn-small.confirm {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
  box-shadow: 0 6rpx 16rpx rgba(46, 204, 113, 0.4);
}

/* 庆祝特效 */
.confetti-compact {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 999;
  display: flex;
  justify-content: space-around;
}

.confetti-item {
  font-size: 40rpx;
  animation: fall 2s ease-in-out infinite;
}

@keyframes fall {
  0% {
    transform: translateY(-100rpx) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(720deg);
    opacity: 0;
  }
}

/* iPad 横屏适配 */
@media (min-width: 768px) and (orientation: landscape) {
  .container {
    padding: 10rpx;
  }
  
  .avatar-large {
    font-size: 56rpx;
  }
  
  .card-normal {
    width: 50rpx;
    height: 76rpx;
  }
}
