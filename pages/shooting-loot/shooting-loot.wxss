/* pages/shooting-loot/shooting-loot.wxss - 完整版 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0f1a 0%, #1a1a2e 100%);
  padding: 20rpx;
}

/* 游戏头部 */
.game-header {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.floor-info {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.timer {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
}

.timer.warning {
  color: #ff4444;
  background: rgba(255, 68, 68, 0.2);
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 玩家状态 */
.player-status {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.status-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-label {
  font-size: 24rpx;
  color: #fff;
  width: 100rpx;
}

.bar-bg {
  flex: 1;
  height: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 15rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 15rpx;
  transition: width 0.3s;
}

.hp-bar .bar-fill {
  background: linear-gradient(90deg, #ff4444 0%, #ff6b6b 100%);
}

.armor-bar .bar-fill {
  background: linear-gradient(90deg, #4444ff 0%, #6b6bff 100%);
}

.status-value {
  font-size: 24rpx;
  color: #fff;
  width: 120rpx;
  text-align: right;
}

.weapon-info {
  display: flex;
  justify-content: space-between;
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 10rpx;
}

.weapon-name {
  font-size: 26rpx;
  color: #ffd700;
  font-weight: bold;
}

.ammo-count {
  font-size: 26rpx;
  color: #fff;
}

.gold-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 15rpx;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2) 0%, rgba(255, 165, 0, 0.1) 100%);
  border-radius: 10rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.3);
}

.gold-icon {
  font-size: 32rpx;
}

.gold-value {
  font-size: 32rpx;
  color: #ffd700;
  font-weight: bold;
}

/* 地图容器 */
.map-container {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.map-grid {
  display: grid;
  grid-template-columns: repeat(8, 80rpx);
  gap: 4rpx;
}

.cell {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cell.wall {
  background: rgba(100, 100, 100, 0.5);
}

.cell-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.wall-icon {
  font-size: 40rpx;
}

.entity {
  font-size: 40rpx;
  position: absolute;
  animation: float 2s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5rpx); }
}

.player-entity {
  animation: playerGlow 2s infinite;
  filter: drop-shadow(0 0 10rpx #4caf50);
}

@keyframes playerGlow {
  0%, 100% { filter: drop-shadow(0 0 10rpx #4caf50); }
  50% { filter: drop-shadow(0 0 20rpx #4caf50); }
}

.enemy-entity {
  animation: enemyPulse 1s infinite;
}

@keyframes enemyPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.box-entity {
  animation: boxShake 3s infinite;
}

@keyframes boxShake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(5deg); }
  75% { transform: rotate(-5deg); }
}

.item-entity {
  animation: itemSparkle 2s infinite;
}

@keyframes itemSparkle {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.3); }
}

.exit-entity {
  animation: exitBlink 1s infinite;
}

@keyframes exitBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 控制按钮 */
.controls {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.control-row {
  display: flex;
  gap: 10rpx;
}

.control-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.3);
}

.control-btn:active {
  transform: scale(0.95);
}

/* 药品栏 */
.meds-bar {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.bar-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.meds-grid {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
}

.med-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  padding: 15rpx;
  background: rgba(76, 175, 80, 0.2);
  border: 1rpx solid rgba(76, 175, 80, 0.4);
  border-radius: 15rpx;
  min-width: 120rpx;
}

.med-icon {
  font-size: 40rpx;
}

.med-name {
  font-size: 22rpx;
  color: #fff;
}

.med-heal {
  font-size: 20rpx;
  color: #52c41a;
  font-weight: bold;
}

/* 物资栏 */
.loot-bar {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.loot-grid {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  flex-wrap: wrap;
}

.loot-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 15rpx;
  min-width: 120rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.loot-icon {
  font-size: 40rpx;
}

.loot-name {
  font-size: 22rpx;
  color: #fff;
  text-align: center;
}

.loot-quality {
  font-size: 18rpx;
  font-weight: bold;
}

/* 战斗日志 */
.battle-log {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  padding: 20rpx;
  max-height: 300rpx;
  overflow-y: auto;
  margin-bottom: 20rpx;
}

.log-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 15rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  padding-bottom: 10rpx;
}

.log-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.log-item {
  display: flex;
  gap: 10rpx;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10rpx;
}

.log-time {
  font-size: 20rpx;
  color: #888;
  min-width: 100rpx;
}

.log-message {
  font-size: 24rpx;
  color: #fff;
  flex: 1;
}

/* 游戏提示 */
.game-tip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 15rpx;
  background: rgba(24, 144, 255, 0.15);
  border: 1rpx solid rgba(24, 144, 255, 0.3);
  border-radius: 15rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #1890ff;
  flex: 1;
}
