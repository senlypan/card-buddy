/* pages/shooting-loot/shooting-loot.wxss - 小学生友好版 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

/* 游戏头部 */
.game-header {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.floor-info {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.timer {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.timer.warning {
  color: #fff;
  background: linear-gradient(135deg, #ff4444 0%, #ff6b6b 100%);
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* 玩家状态 */
.player-status {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.status-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-label {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
  width: 100rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.bar-bg {
  flex: 1;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 18rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.bar-fill {
  height: 100%;
  border-radius: 18rpx;
  transition: width 0.3s;
}

.hp-bar .bar-fill {
  background: linear-gradient(90deg, #ff6b6b 0%, #ff8e8e 100%);
  box-shadow: 0 0 10rpx rgba(255, 107, 107, 0.5);
}

.armor-bar .bar-fill {
  background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
  box-shadow: 0 0 10rpx rgba(79, 172, 254, 0.5);
}

.status-value {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
  width: 120rpx;
  text-align: right;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.weapon-info {
  display: flex;
  justify-content: space-between;
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 15rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.weapon-name {
  font-size: 26rpx;
  color: #ffd700;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.ammo-count {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

.gold-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 15rpx;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.3) 0%, rgba(255, 165, 0, 0.2) 100%);
  border-radius: 15rpx;
  border: 2rpx solid rgba(255, 215, 0, 0.5);
}

.gold-icon {
  font-size: 36rpx;
}

.gold-value {
  font-size: 36rpx;
  color: #ffd700;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.gold-label {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

/* 地图容器 */
.map-container {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.map-grid {
  display: grid;
  grid-template-columns: repeat(8, 80rpx);
  gap: 6rpx;
}

.cell {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.cell.wall {
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.cell-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.wall-icon {
  font-size: 44rpx;
}

.entity {
  font-size: 44rpx;
  position: absolute;
  animation: float 2s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.player-entity {
  animation: playerGlow 2s infinite;
  filter: drop-shadow(0 0 15rpx #4caf50);
}

@keyframes playerGlow {
  0%, 100% { filter: drop-shadow(0 0 15rpx #4caf50); }
  50% { filter: drop-shadow(0 0 25rpx #4caf50); }
}

.enemy-entity {
  animation: robotMove 1.5s infinite;
}

@keyframes robotMove {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(5rpx); }
}

.box-entity {
  animation: boxOpen 2s infinite;
}

@keyframes boxOpen {
  0%, 100% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(10deg) scale(1.1); }
}

.item-entity {
  animation: itemSparkle 1.5s infinite;
  filter: drop-shadow(0 0 10rpx #ffd700);
}

@keyframes itemSparkle {
  0%, 100% { filter: drop-shadow(0 0 10rpx #ffd700) brightness(1); }
  50% { filter: drop-shadow(0 0 20rpx #ffd700) brightness(1.3); }
}

.exit-entity {
  animation: exitBlink 1s infinite;
  filter: drop-shadow(0 0 15rpx #4caf50);
}

@keyframes exitBlink {
  0%, 100% { opacity: 1; filter: drop-shadow(0 0 15rpx #4caf50); }
  50% { opacity: 0.6; filter: drop-shadow(0 0 25rpx #4caf50); }
}

/* 地图图例 */
.map-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.3);
}

.legend-item {
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.15);
  padding: 8rpx 15rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

/* 控制按钮 */
.controls {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.control-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.control-row {
  display: flex;
  gap: 15rpx;
}

.control-btn {
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.3);
  border: 3rpx solid rgba(255, 255, 255, 0.4);
}

.control-btn:active {
  transform: scale(0.95);
}

/* 药品栏 */
.meds-bar {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.bar-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.meds-grid {
  display: flex;
  gap: 15rpx;
  overflow-x: auto;
}

.med-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 15rpx;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.3) 0%, rgba(76, 175, 80, 0.1) 100%);
  border: 2rpx solid rgba(76, 175, 80, 0.5);
  border-radius: 15rpx;
  min-width: 130rpx;
}

.med-icon {
  font-size: 44rpx;
}

.med-name {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.med-heal {
  font-size: 22rpx;
  color: #52c41a;
  font-weight: bold;
}

/* 物资栏 */
.loot-bar {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.loot-grid {
  display: flex;
  gap: 15rpx;
  overflow-x: auto;
  flex-wrap: wrap;
}

.loot-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 15rpx;
  min-width: 130rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.loot-icon {
  font-size: 44rpx;
}

.loot-name {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
  text-align: center;
}

.loot-quality {
  font-size: 20rpx;
  font-weight: bold;
}

/* 行动记录 */
.battle-log {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 20rpx;
  max-height: 300rpx;
  overflow-y: auto;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.log-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 15rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.3);
  padding-bottom: 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.log-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.log-item {
  display: flex;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
}

.log-item.highlight {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.3) 0%, rgba(255, 165, 0, 0.2) 100%);
  border: 2rpx solid rgba(255, 215, 0, 0.5);
}

.log-message {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

/* 游戏提示 */
.game-tip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.3) 0%, rgba(24, 144, 255, 0.15) 100%);
  border: 2rpx solid rgba(24, 144, 255, 0.5);
  border-radius: 20rpx;
}

.tip-icon {
  font-size: 36rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
  flex: 1;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}
