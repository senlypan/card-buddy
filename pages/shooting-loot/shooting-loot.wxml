<!--pages/shooting-loot/shooting-loot.wxml - 完整版-->
<view class="container">
  <!-- 游戏状态显示 -->
  <view class="game-header" wx:if="{{gameState === 'playing'}}">
    <view class="info-row">
      <view class="floor-info">📍 {{floor}}/{{maxFloors}} 楼</view>
      <view class="timer {{timer < 60 ? 'warning' : ''}}">⏱️ {{timer}}s</view>
    </view>
    
    <!-- 玩家状态 -->
    <view class="player-status">
      <view class="status-bar hp-bar">
        <text class="status-label">❤️ 生命</text>
        <view class="bar-bg">
          <view class="bar-fill" style="width: {{player.hp / player.maxHp * 100}}%"></view>
        </view>
        <text class="status-value">{{player.hp}}/{{player.maxHp}}</text>
      </view>
      
      <view class="status-bar armor-bar" wx:if="{{player.armor > 0}}">
        <text class="status-label">🛡️ 护甲</text>
        <view class="bar-bg">
          <view class="bar-fill" style="width: {{player.armor / player.maxArmor * 100}}%"></view>
        </view>
        <text class="status-value">{{player.armor}}/{{player.maxArmor}}</text>
      </view>
      
      <view class="weapon-info" wx:if="{{player.weapon}}">
        <text class="weapon-name">{{player.weapon.name}}</text>
        <text class="ammo-count">🔫 {{player.ammo}}/{{player.weapon.magazine}}</text>
      </view>
      
      <view class="gold-info">
        <text class="gold-icon">🪙</text>
        <text class="gold-value">{{player.gold}}</text>
      </view>
    </view>
  </view>

  <!-- 游戏地图 -->
  <view class="map-container" wx:if="{{gameState === 'playing'}}">
    <view class="map-grid">
      <view 
        class="cell {{displayMap[rowIndex][colIndex].type}}"
        wx:for="{{displayMap}}"
        wx:for-item="row"
        wx:for-index="rowIndex"
        wx:key="*this">
        
        <view 
          class="cell-inner"
          wx:for="{{row}}"
          wx:for-item="cell"
          wx:for-index="colIndex"
          wx:key="*this"
          data-x="{{rowIndex}}"
          data-y="{{colIndex}}"
          bindtap="onMove"
          data-direction="{{colIndex > player.position.y ? 'right' : (colIndex < player.position.y ? 'left' : (rowIndex > player.position.x ? 'down' : 'up'))}}">
          
          <!-- 玩家位置 -->
          <text class="entity player-entity" wx:if="{{cell.isPlayer}}">👤</text>
          
          <!-- 敌人 -->
          <text class="entity enemy-entity" wx:elif="{{cell.hasEnemy}}">👾</text>
          
          <!-- 物资箱 -->
          <text class="entity box-entity" wx:elif="{{cell.hasLootBox}}">📦</text>
          
          <!-- 物品 -->
          <text class="entity item-entity" wx:elif="{{cell.hasItem}}">💎</text>
          
          <!-- 撤离点 -->
          <text class="entity exit-entity" wx:elif="{{cell.isExit}}">🚁</text>
          
          <!-- 墙壁图标 -->
          <text wx:if="{{cell.type === 'wall'}}" class="wall-icon">🧱</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="controls" wx:if="{{gameState === 'playing'}}">
    <view class="control-row">
      <view class="control-btn" bindtap="onMove" data-direction="up">⬆️</view>
    </view>
    <view class="control-row">
      <view class="control-btn" bindtap="onMove" data-direction="left">⬅️</view>
      <view class="control-btn" bindtap="onMove" data-direction="down">⬇️</view>
      <view class="control-btn" bindtap="onMove" data-direction="right">➡️</view>
    </view>
  </view>

  <!-- 药品快捷栏 -->
  <view class="meds-bar" wx:if="{{gameState === 'playing' && meds.length > 0}}">
    <view class="bar-title">💊 药品</view>
    <view class="meds-grid">
      <view 
        class="med-item" 
        wx:for="{{meds}}" 
        wx:key="index" 
        wx:for-index="idx"
        bindtap="useMed"
        data-index="{{idx}}">
        <text class="med-icon">{{item.heal >= 100 ? '🏥' : (item.heal >= 50 ? '💉' : '🩹')}}</text>
        <text class="med-name">{{item.name}}</text>
        <text class="med-heal">+{{item.heal}}</text>
      </view>
    </view>
  </view>

  <!-- 物资栏 -->
  <view class="loot-bar" wx:if="{{gameState === 'playing' && loot.length > 0}}">
    <view class="bar-title">🎒 物资 ({{loot.length}}件)</view>
    <view class="loot-grid">
      <view class="loot-item" wx:for="{{loot}}" wx:key="index" wx:for-index="idx">
        <text class="loot-icon">{{item.type === 'weapon' ? '🔫' : (item.type === 'armor' ? '🦺' : '💰')}}</text>
        <text class="loot-name">{{item.name}}</text>
        <text class="loot-quality" style="color: {{qualityColors[item.quality.toLowerCase()]}}">{{item.quality}}</text>
      </view>
    </view>
  </view>

  <!-- 战斗日志 -->
  <view class="battle-log" wx:if="{{gameState === 'playing'}}">
    <view class="log-title">📜 行动记录</view>
    <view class="log-content">
      <view class="log-item" wx:for="{{battleLog}}" wx:key="index">
        <text class="log-time">{{item.time}}</text>
        <text class="log-message">{{item.message}}</text>
      </view>
    </view>
  </view>

  <!-- 游戏提示 -->
  <view class="game-tip" wx:if="{{gameState === 'playing'}}">
    <text class="tip-icon">💡</text>
    <text class="tip-text">{{gameTip}}</text>
  </view>
</view>
