/* pages/doudizhu/doudizhu.wxss - 重新设计版 */

/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding-bottom: 20rpx;
}

/* 游戏信息栏 */
.game-info {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 15rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.points {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFD700;
}

/* 角色选择 */
.select-area {
  padding: 60rpx 20rpx;
  text-align: center;
}

.select-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 15rpx;
}

.select-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 40rpx;
}

/* 难度选择 */
.difficulty-section {
  margin-bottom: 40rpx;
}

.difficulty-title {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 20rpx;
}

.difficulty-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 40rpx;
}

.difficulty-btn {
  width: 200rpx;
  padding: 30rpx 15rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s;
}

.difficulty-btn:active {
  transform: scale(0.95);
}

.difficulty-btn.active {
  background: rgba(255, 215, 0, 0.2);
  border-color: rgba(255, 215, 0, 0.6);
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.4);
}

.difficulty-emoji {
  font-size: 48rpx;
}

.difficulty-name {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}

.difficulty-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.role-buttons {
  display: flex;
  gap: 30rpx;
  justify-content: center;
}

.role-btn {
  width: 280rpx;
  padding: 40rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.role-btn:active {
  transform: scale(0.95);
}

.role-emoji {
  font-size: 64rpx;
}

.role-name {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.role-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.landlord-btn {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.2) 0%, rgba(255, 107, 107, 0.1) 100%);
  border-color: rgba(255, 107, 107, 0.4);
}

.farmer-btn {
  background: linear-gradient(135deg, rgba(78, 205, 196, 0.2) 0%, rgba(78, 205, 196, 0.1) 100%);
  border-color: rgba(78, 205, 196, 0.4);
}

/* 游戏界面 */
.game-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

/* 对手区域 */
.opponent-section {
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.05);
  margin: 10rpx;
  border-radius: 16rpx;
}

.opponent-header {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.player-avatar {
  font-size: 40rpx;
}

.player-name {
  font-size: 26rpx;
  font-weight: bold;
  color: white;
}

.card-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.eye-icon {
  font-size: 32rpx;
  opacity: 0.6;
  transition: all 0.3s;
}

.eye-icon:active {
  opacity: 1;
  transform: scale(1.2);
}

/* 对手手牌 */
.opponent-hand {
  min-height: 120rpx;
  display: flex;
  justify-content: center;
}

.cards-row {
  display: flex;
  justify-content: center;
  padding: 10rpx 0;
}

.op-card, .my-card, .play-card {
  width: 60rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  flex-shrink: 0;
}

.c-top, .c-bottom {
  position: absolute;
  font-size: 20rpx;
  font-weight: bold;
  line-height: 1;
}

.c-top {
  top: 5rpx;
  left: 5rpx;
}

.c-bottom {
  bottom: 5rpx;
  right: 5rpx;
  transform: rotate(180deg);
}

.c-top.red, .c-bottom.red {
  color: #e74c3c;
}

.c-top.black, .c-bottom.black {
  color: #2c3e50;
}

/* 对手牌背 */
.opponent-back {
  min-height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.back-cards {
  display: flex;
  justify-content: center;
}

.card-back {
  width: 50rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-radius: 8rpx;
  border: 2rpx solid #c0392b;
  margin-left: -25rpx;
}

.card-back:first-child {
  margin-left: 0;
}

.card-count-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 出牌区域（左右布局） */
.play-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.05);
  margin: 10rpx;
  border-radius: 16rpx;
  min-height: 140rpx;
}

.play-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.play-box.active {
  background: rgba(255, 215, 0, 0.15);
  border-color: rgba(255, 215, 0, 0.4);
}

.play-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.play-cards {
  display: flex;
  justify-content: center;
  min-height: 100rpx;
  align-items: center;
}

.no-cards {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.3);
}

.vs-icon {
  font-size: 40rpx;
  margin: 0 20rpx;
}

/* 游戏提示 */
.message-box {
  text-align: center;
  padding: 10rpx;
  margin: 0 10rpx;
}

.message {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

/* 我的手牌区域 */
.my-section {
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.05);
  margin: 10rpx;
  border-radius: 16rpx;
}

.my-header {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.my-hand {
  min-height: 120rpx;
  display: flex;
  justify-content: center;
}

.my-card.selected {
  transform: translateY(-15rpx);
  box-shadow: 0 8rpx 20rpx rgba(255, 215, 0, 0.5);
  border-color: #FFD700;
}

/* 操作按钮 */
.action-area {
  padding: 20rpx 15rpx;
  text-align: center;
}

.button-group {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.btn {
  padding: 15rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}

.btn:active {
  transform: scale(0.95);
}

.btn.play {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
}

.btn.pass {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: white;
}

.waiting {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 结算弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: 32rpx;
  padding: 60rpx 80rpx;
  text-align: center;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.5);
  min-width: 400rpx;
}

.result-emoji {
  font-size: 100rpx;
  display: block;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: block;
  margin: 20rpx 0 12rpx;
}

.result-points {
  font-size: 36rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: bold;
  display: block;
}

.countdown {
  margin-top: 20rpx;
  padding: 10rpx 24rpx;
  background: rgba(52, 152, 219, 0.2);
  border-radius: 16rpx;
}

.countdown text {
  font-size: 22rpx;
  color: #3498db;
}


