/* pages/doudizhu/doudizhu.wxss - iPad 适配版 */

/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2c3e50 0%, #34495e 50%, #1a252f 100%);
  padding-bottom: 30rpx;
  max-width: 1024px;
  margin: 0 auto;
}

/* 游戏信息栏 */
.game-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  margin: 15rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.3);
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.points {
  font-size: 34rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 16rpx rgba(255, 215, 0, 0.5);
}

/* 玩家区域 */
.player-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 20rpx;
  margin: 15rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.4);
}

.landlord-area {
  background: linear-gradient(135deg, rgba(230, 126, 34, 0.15) 0%, rgba(211, 84, 0, 0.05) 100%);
}

.my-area {
  background: linear-gradient(135deg, rgba(46, 204, 113, 0.15) 0%, rgba(39, 174, 96, 0.05) 100%);
}

.avatar {
  font-size: 70rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.5));
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 15rpx;
}

.name {
  font-size: 26rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.cards {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
  justify-content: center;
  max-width: 100%;
}

.card-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: bold;
  display: flex;
  align-items: center;
  margin-left: 10rpx;
}

.card {
  width: 50rpx;
  height: 74rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.4);
  position: relative;
}

.card.back {
  background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
  border: 2rpx solid #d35400;
}

.card.back::after {
  content: '🃏';
  font-size: 28rpx;
}

.card.large {
  width: 64rpx;
  height: 94rpx;
  border-width: 2rpx;
}

.card-text {
  font-size: 22rpx;
  font-weight: bold;
}

.card.large .card-text {
  font-size: 28rpx;
}

/* 扑克牌花色颜色 */
.card-red {
  color: #e74c3c;
}

.card-black {
  color: #2c3e50;
}

/* 牌型提示 */
.hand-type {
  background: linear-gradient(135deg, rgba(230, 126, 34, 0.3) 0%, rgba(211, 84, 0, 0.2) 100%);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  margin-top: 8rpx;
  border: 1rpx solid rgba(230, 126, 34, 0.4);
}

.my-hand-type {
  background: linear-gradient(135deg, rgba(46, 204, 113, 0.3) 0%, rgba(39, 174, 96, 0.2) 100%);
  border: 1rpx solid rgba(46, 204, 113, 0.4);
}

.hand-type-text {
  font-size: 22rpx;
  font-weight: bold;
  color: white;
}

/* 消息框 */
.message-box {
  text-align: center;
  padding: 20rpx;
  margin: 12rpx 15rpx;
}

.message {
  font-size: 30rpx;
  color: white;
  font-weight: bold;
  line-height: 1.5;
  text-shadow: 0 0 16rpx rgba(255, 255, 255, 0.5);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.8; }
}

/* 操作按钮区域 */
.action-area {
  padding: 20rpx 15rpx;
}

.big-btn {
  width: 85%;
  height: 100rpx;
  margin: 12rpx auto;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.4);
  transition: all 0.2s ease;
}

.big-btn:active {
  transform: scale(0.95);
}

.start-btn {
  background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
  color: white;
}

.next-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
}

/* 结算弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: 32rpx;
  padding: 50rpx 70rpx;
  text-align: center;
  animation: popIn 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.5);
}

@keyframes popIn {
  from {
    transform: scale(0.5) rotate(-10deg);
    opacity: 0;
  }
  to {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.result-emoji {
  font-size: 110rpx;
  display: block;
  animation: bounce 0.8s ease;
}

.result-title {
  font-size: 44rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  margin: 20rpx 0 12rpx;
}

.result-points {
  font-size: 40rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: bold;
  display: block;
}

.result-subtitle {
  font-size: 26rpx;
  color: #95a5a6;
  display: block;
  margin-top: 16rpx;
}

/* 关闭按钮 */
.close-btn {
  margin-top: 28rpx;
  padding: 14rpx 40rpx;
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  border-radius: 28rpx;
  display: inline-block;
}

.close-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.close-btn text {
  font-size: 26rpx;
  color: white;
  font-weight: bold;
}

/* 倒计时 */
.countdown {
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  background: rgba(52, 152, 219, 0.2);
  border-radius: 20rpx;
}

.countdown text {
  font-size: 24rpx;
  color: #3498db;
}

/* 庆祝特效 */
.confetti {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 999;
}

.confetti-item {
  position: absolute;
  top: -50rpx;
  font-size: 56rpx;
  animation: fall 2.5s ease-in-out infinite;
}

.confetti-item:nth-child(1) { animation-delay: 0s; }
.confetti-item:nth-child(2) { animation-delay: 0.3s; }
.confetti-item:nth-child(3) { animation-delay: 0.6s; }
.confetti-item:nth-child(4) { animation-delay: 0.9s; }
.confetti-item:nth-child(5) { animation-delay: 1.2s; }

@keyframes fall {
  0% {
    top: -50rpx;
    transform: rotate(0deg) scale(0.8);
    opacity: 1;
  }
  100% {
    top: 100vh;
    transform: rotate(720deg) scale(1.2);
    opacity: 0;
  }
}
