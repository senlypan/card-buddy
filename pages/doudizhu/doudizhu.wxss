/* pages/doudizhu/doudizhu.wxss */
.coming-soon {
  text-align: center;
}

.emoji {
  font-size: 150rpx;
  display: block;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 32rpx;
  color: #999;
  display: block;
  margin-bottom: 60rpx;
}

.back-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: inline-block;
  box-shadow: 0 8rpx 16rpx rgba(255, 107, 107, 0.3);
}
