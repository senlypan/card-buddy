/* pages/doudizhu/doudizhu.wxss - 角色选择版 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2c3e50 0%, #34495e 50%, #1a252f 100%);
  padding-bottom: 20rpx;
  max-width: 1024px;
  margin: 0 auto;
}

/* 角色选择界面 */
.select-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.select-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
}

.select-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 80rpx;
  text-align: center;
  line-height: 1.6;
}

.role-buttons {
  display: flex;
  gap: 40rpx;
  justify-content: center;
}

.role-btn {
  width: 280rpx;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.role-btn:active {
  transform: scale(0.95);
}

.landlord-btn {
  background: linear-gradient(135deg, rgba(230, 126, 34, 0.3) 0%, rgba(211, 84, 0, 0.2) 100%);
  border-color: rgba(230, 126, 34, 0.5);
}

.farmer-btn {
  background: linear-gradient(135deg, rgba(46, 204, 113, 0.3) 0%, rgba(39, 174, 96, 0.2) 100%);
  border-color: rgba(46, 204, 113, 0.5);
}

.role-emoji {
  font-size: 100rpx;
}

.role-name {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.role-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.game-info {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 12rpx 15rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 12rpx;
  margin: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.points {
  font-size: 28rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 对手区域 */
.opponent-area {
  margin: 10rpx;
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.player-info-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 15rpx;
  padding: 10rpx;
  margin-bottom: 10rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.player-avatar {
  font-size: 36rpx;
}

.player-name {
  font-size: 24rpx;
  font-weight: bold;
  color: white;
}

.card-count-badge {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* 对手牌背 */
.opponent-cards {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 120rpx;
  position: relative;
}

.card-back-stack {
  position: relative;
  width: 400rpx;
  height: 100rpx;
}

.card-back {
  position: absolute;
  width: 50rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
  border-radius: 8rpx;
  border: 2rpx solid #c0392b;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
}

.card-back::after {
  content: '🃏';
  font-size: 24rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.card-count-overlay {
  position: absolute;
  bottom: -25rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(230, 126, 34, 0.9);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.play-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 15rpx;
  margin: 10rpx;
  gap: 15rpx;
}

.played-cards {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  min-width: 200rpx;
  min-height: 100rpx;
  justify-content: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.played-cards.active {
  background: rgba(255, 215, 0, 0.15);
  border-color: #FFD700;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
}

.played-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.played-cards-inner {
  display: flex;
  gap: 4rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.mini-card {
  width: 40rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.mini-card-text {
  font-size: 18rpx;
  font-weight: bold;
}

.mini-card-text.red {
  color: #e74c3c;
}

.mini-card-text.black {
  color: #2c3e50;
}

.no-cards {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.3);
}

.vs-badge {
  font-size: 40rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

.message-box {
  text-align: center;
  padding: 15rpx;
  margin: 8rpx 15rpx;
}

.message {
  font-size: 26rpx;
  color: white;
  font-weight: bold;
  line-height: 1.4;
  text-shadow: 0 0 12rpx rgba(255, 255, 255, 0.5);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 我的手牌 - 紧凑堆叠 */
.my-cards-container {
  padding: 15rpx 10rpx;
  margin: 8rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  overflow-x: auto;
}

.cards-compact {
  display: flex;
  justify-content: center;
  padding: 10rpx 0;
  min-height: 90rpx;
}

.card-compact {
  width: 56rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  transition: transform 0.2s, box-shadow 0.2s;
}

.card-compact:active {
  transform: scale(0.95);
}

.card-compact.selected {
  transform: translateY(-15rpx);
  box-shadow: 0 8rpx 16rpx rgba(255, 215, 0, 0.5);
  border-color: #FFD700;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFF3CC 100%);
}

.card-compact.auto-highlight {
  transform: translateY(-20rpx);
  box-shadow: 0 12rpx 24rpx rgba(255, 0, 0, 0.6);
  border-color: #FF4444;
  background: linear-gradient(135deg, #FFE6E6 0%, #FFCCCC 100%);
  animation: pulse-card 0.5s ease-in-out infinite;
}

@keyframes pulse-card {
  0%, 100% {
    box-shadow: 0 12rpx 24rpx rgba(255, 0, 0, 0.6);
  }
  50% {
    box-shadow: 0 12rpx 32rpx rgba(255, 0, 0, 0.8);
  }
}

.corner-top {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  font-size: 18rpx;
  font-weight: bold;
  line-height: 1;
}

.corner-bottom {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  font-size: 18rpx;
  font-weight: bold;
  line-height: 1;
  transform: rotate(180deg);
}

.corner-top.red,
.corner-bottom.red {
  color: #e74c3c;
}

.corner-top.black,
.corner-bottom.black {
  color: #2c3e50;
}

.card-tip {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 10rpx;
}

.action-area {
  padding: 15rpx 10rpx;
}

.button-group {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.medium-btn {
  min-width: 28%;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.4);
  transition: all 0.2s ease;
}

.medium-btn:active {
  transform: scale(0.95);
}

.auto-btn {
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: white;
}

.hint-btn {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: white;
}

.play-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
}

.pass-btn {
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  color: white;
}

.waiting-text {
  text-align: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: bold;
}

.big-btn {
  width: 85%;
  height: 90rpx;
  margin: 10rpx auto;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  transition: all 0.2s ease;
}

.big-btn:active {
  transform: scale(0.95);
}

.next-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: 28rpx;
  padding: 40rpx 60rpx;
  text-align: center;
  animation: popIn 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.5);
}

@keyframes popIn {
  from {
    transform: scale(0.5) rotate(-10deg);
    opacity: 0;
  }
  to {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.result-emoji {
  font-size: 90rpx;
  display: block;
  animation: bounce 0.8s ease;
}

.result-title {
  font-size: 38rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  margin: 16rpx 0 10rpx;
}

.result-points {
  font-size: 34rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: bold;
  display: block;
}

.result-subtitle {
  font-size: 24rpx;
  color: #95a5a6;
  display: block;
  margin-top: 12rpx;
}

.close-btn {
  margin-top: 24rpx;
  padding: 12rpx 35rpx;
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  border-radius: 24rpx;
  display: inline-block;
}

.close-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.close-btn text {
  font-size: 24rpx;
  color: white;
  font-weight: bold;
}

.countdown {
  margin-top: 12rpx;
  padding: 8rpx 20rpx;
  background: rgba(52, 152, 219, 0.2);
  border-radius: 16rpx;
}

.countdown text {
  font-size: 22rpx;
  color: #3498db;
}

.confetti {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 999;
}

.confetti-item {
  position: absolute;
  top: -40rpx;
  font-size: 48rpx;
  animation: fall 2.5s ease-in-out infinite;
}

.confetti-item:nth-child(1) { animation-delay: 0s; }
.confetti-item:nth-child(2) { animation-delay: 0.3s; }
.confetti-item:nth-child(3) { animation-delay: 0.6s; }
.confetti-item:nth-child(4) { animation-delay: 0.9s; }
.confetti-item:nth-child(5) { animation-delay: 1.2s; }

@keyframes fall {
  0% {
    top: -40rpx;
    transform: rotate(0deg) scale(0.8);
    opacity: 1;
  }
  100% {
    top: 100vh;
    transform: rotate(720deg) scale(1.2);
    opacity: 0;
  }
}
