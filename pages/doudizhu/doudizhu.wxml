<!--pages/doudizhu/doudizhu.wxml - 重新设计版-->
<view class="container">
  <!-- 游戏信息栏 -->
  <view class="game-info">
    <view class="info-item">
      <text class="label">第 {{round}} 局</text>
    </view>
    <view class="info-item">
      <text class="label">积分</text>
      <text class="points">{{myPoints}}</text>
    </view>
    <view class="info-item" bindtap="goHome">
      <text class="label">🏠</text>
    </view>
  </view>

  <!-- 角色选择界面 -->
  <view class="select-area" wx:if="{{gamePhase === 'select'}}">
    <!-- 标题区域 -->
    <view class="title-section">
      <view class="main-title-wrapper">
        <text class="title-emoji">🃏</text>
        <text class="main-title-text">斗地主</text>
      </view>
      <text class="sub-title">选择难度和角色开始游戏</text>
    </view>
    
    <!-- 难度选择 -->
    <view class="difficulty-section">
      <view class="section-header">
        <text class="section-icon">🎯</text>
        <text class="section-title">选择难度</text>
      </view>
      
      <view class="difficulty-row">
        <view class="difficulty-btn-small {{aiDifficulty === 'easy' ? 'active' : ''}}" 
              bindtap="selectDifficulty" 
              data-difficulty="easy">
          <text class="btn-emoji">😊</text>
          <text class="btn-name">简单</text>
          <text class="btn-rate">30%</text>
        </view>
        
        <view class="difficulty-btn-small {{aiDifficulty === 'normal' ? 'active' : ''}}" 
              bindtap="selectDifficulty" 
              data-difficulty="normal">
          <text class="btn-emoji">🎯</text>
          <text class="btn-name">普通</text>
          <text class="btn-rate">50%</text>
        </view>
        
        <view class="difficulty-btn-small {{aiDifficulty === 'hell' ? 'active' : ''}}" 
              bindtap="selectDifficulty" 
              data-difficulty="hell">
          <text class="btn-emoji">🔥</text>
          <text class="btn-name">地狱</text>
          <text class="btn-rate">75%</text>
        </view>
      </view>
    </view>
    
    <!-- 角色选择 -->
    <view class="role-section">
      <view class="section-header">
        <text class="section-icon">🎭</text>
        <text class="section-title">第二步：选择角色</text>
      </view>
      
      <view class="role-cards">
        <view class="role-card landlord-card" bindtap="selectLandlord">
          <view class="role-card-header">
            <view class="emoji-badge-row">
              <text class="role-card-emoji">🤠</text>
              <view class="role-card-badge-wrapper">
                <text class="role-card-badge">⭐ 推荐</text>
              </view>
            </view>
          </view>
          <view class="role-card-body">
            <text class="role-card-name">地主</text>
            <view class="role-card-features">
              <view class="feature-item">
                <text class="feature-icon">🃏</text>
                <text class="feature-text">20 张牌</text>
              </view>
              <view class="feature-item">
                <text class="feature-icon">⚡</text>
                <text class="feature-text">先出牌</text>
              </view>
            </view>
          </view>
        </view>
        
        <view class="role-card farmer-card" bindtap="selectFarmer">
          <view class="role-card-header">
            <text class="role-card-emoji">👦</text>
          </view>
          <view class="role-card-body">
            <text class="role-card-name">农民</text>
            <view class="role-card-features">
              <view class="feature-item">
                <text class="feature-icon">🃏</text>
                <text class="feature-text">17 张牌</text>
              </view>
              <view class="feature-item">
                <text class="feature-icon">🛡️</text>
                <text class="feature-text">后出牌</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 游戏界面 -->
  <view class="game-content" wx:if="{{gamePhase === 'playing' || gamePhase === 'dealing' || gamePhase === 'result'}}">
    
    <!-- 对手区域（上方） -->
    <view class="opponent-section">
      <view class="opponent-header">
        <text class="player-avatar">🤠</text>
        <text class="player-name">{{isLandlord ? '我（地主）' : '地主'}}</text>
        <text class="card-count">{{landlordCards.length}}张</text>
        <!-- 明牌小眼睛 -->
        <text class="eye-icon" bindtap="toggleOpponentCards">👁️</text>
      </view>
      
      <!-- 对手手牌 -->
      <view class="opponent-hand" wx:if="{{showOpponentCards}}">
        <view class="cards-row">
          <view class="op-card" wx:for="{{landlordCardsDisplay}}" wx:for-item="card" wx:key="*this" style="margin-left: {{index > 0 ? '-35' : '0'}}rpx;">
            <text class="c-top {{card.isRed ? 'red' : 'black'}}">{{card.text}}</text>
            <text class="c-bottom {{card.isRed ? 'red' : 'black'}}">{{card.text}}</text>
          </view>
        </view>
      </view>
      
      <!-- 对手牌背 -->
      <view class="opponent-back" wx:else>
        <view class="back-cards">
          <view class="card-back" wx:for="{{landlordCards.length}}" wx:key="*this"></view>
        </view>
        <text class="card-count-text">{{landlordCards.length}}张</text>
      </view>
    </view>

    <!-- 出牌区域（中间，左右布局） -->
    <view class="play-section">
      <!-- 对手出的牌（左） -->
      <view class="play-box {{lastHandPlayer === 'landlord' ? 'active' : ''}}">
        <text class="play-label" wx:if="{{lastHandPlayer === 'landlord'}}">对手：</text>
        <view class="play-cards">
          <view class="play-card" wx:for="{{lastHandPlayer === 'landlord' ? lastHandCards : []}}" wx:for-item="card" wx:key="*this" style="margin-left: {{index > 0 ? '-30' : '0'}}rpx;">
            <text class="c-top {{card.isRed ? 'red' : 'black'}}">{{card.text}}</text>
            <text class="c-bottom {{card.isRed ? 'red' : 'black'}}">{{card.text}}</text>
          </view>
          <text class="no-cards" wx:if="{{!lastHand || lastHandPlayer !== 'landlord'}}">-</text>
        </view>
      </view>
      
      <!-- VS 标识 -->
      <view class="vs-icon">⚔️</view>
      
      <!-- 我出的牌（右） -->
      <view class="play-box {{lastHandPlayer === 'me' ? 'active' : ''}}">
        <text class="play-label" wx:if="{{lastHandPlayer === 'me'}}">我：</text>
        <view class="play-cards">
          <view class="play-card" wx:for="{{lastHandPlayer === 'me' ? lastHandCards : []}}" wx:for-item="card" wx:key="*this" style="margin-left: {{index > 0 ? '-30' : '0'}}rpx;">
            <text class="c-top {{card.isRed ? 'red' : 'black'}}">{{card.text}}</text>
            <text class="c-bottom {{card.isRed ? 'red' : 'black'}}">{{card.text}}</text>
          </view>
          <text class="no-cards" wx:if="{{!lastHand || lastHandPlayer !== 'me'}}">-</text>
        </view>
      </view>
    </view>

    <!-- 游戏提示 -->
    <view class="message-box">
      <text class="message">{{message}}</text>
    </view>

    <!-- 我的手牌区域（底部） -->
    <view class="my-section">
      <view class="my-header">
        <text class="player-avatar">👦</text>
        <text class="player-name">我</text>
        <text class="card-count" wx:if="{{selectedCount > 0}}">已选 {{selectedCount}}张</text>
      </view>
      
      <!-- 我的手牌 -->
      <view class="my-hand">
        <view class="cards-row">
          <view class="my-card {{item.selected ? 'selected' : ''}}" 
                wx:for="{{myCardsDisplay}}" 
                wx:for-item="item" 
                wx:key="*this"
                data-index="{{item.index}}"
                bindtap="toggleCard"
                style="margin-left: {{index > 0 ? '-40' : '0'}}rpx;">
            <text class="c-top {{item.isRed ? 'red' : 'black'}}">{{item.text}}</text>
            <text class="c-bottom {{item.isRed ? 'red' : 'black'}}">{{item.text}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-area" wx:if="{{gamePhase === 'playing' && isMyTurn}}">
      <view class="button-group">
        <view class="btn play" bindtap="playCards">🎴 出牌 ({{selectedCount}})</view>
        <view class="btn pass" bindtap="pass" wx:if="{{lastHand && lastHandPlayer !== 'me'}}">✋ 不要</view>
      </view>
    </view>

    <!-- 等待提示 -->
    <view class="action-area" wx:if="{{gamePhase === 'playing' && !isMyTurn}}">
      <text class="waiting">⏳ 等待其他玩家...</text>
    </view>

    <!-- 结算弹窗 -->
    <view class="modal" wx:if="{{showResult}}" catchtap="stopClose">
      <view class="modal-content" catchtap="stopClose">
        <text class="result-emoji">{{resultEmoji}}</text>
        <text class="result-title">{{resultTitle}}</text>
        <text class="result-points">{{resultPoints}}</text>
        
        <view class="countdown" wx:if="{{countdown > 0}}">
          <text>{{countdown}}秒后重新开始</text>
        </view>
      </view>
    </view>
  </view>
</view>
