/* pages/profile/profile.wxss */

.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #FFE5E5 0%, #FFF5F5 100%);
  min-height: 100vh;
}

/* 用户信息卡片 */
.profile-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
}

.avatar {
  font-size: 100rpx;
  margin-bottom: 10rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
}

.points-display {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 15rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 5rpx;
}

.points-value {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
}

/* 统计卡片 */
.stats-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 25rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B6B;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 菜单卡片 */
.menu-card {
  background: white;
  border-radius: 24rpx;
  padding: 10rpx 0;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f9f9f9;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 提示卡片 */
.tips-card {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2E7D32;
  display: block;
  margin-bottom: 15rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #388E3C;
  line-height: 1.6;
}
